<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="system" method="upgrade">
	<name>System - Markdown Mirror</name>
	<author>Buchs</author>
	<version>0.5.0</version>
	<description>Automatically serves Markdown to AI agents based on User-Agent or Accept header. Designed for AI agent consumption.</description>
	<joomlaVersion>5.0,6.0</joomlaVersion>
	<namespace path="src">Buchs\Plugin\System\Markdownmirror</namespace>
	<files>
		<folder plugin="markdownmirror">services</folder>
		<folder>src</folder>
		<folder>vendor</folder>
	</files>
	<updateservers>
		<server type="extension" name="plg_system_markdownmirror">https://raw.githubusercontent.com/Buchs-Dev/markdownmirror/master/updates.xml</server>
	</updateservers>
</extension>