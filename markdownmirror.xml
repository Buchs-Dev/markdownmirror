<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="system" method="upgrade">
	<name>System - Markdown Mirror</name>
	<author>Buchs</author>
	<version>0.2.0</version>
	<description>Outputs Markdown versions of Joomla pages when ?md=1 is present. Designed for AI agent consumption.</description>
	<joomlaVersion>5.0,6.0</joomlaVersion>
	<files>
		<filename plugin="markdownmirror">markdownmirror.php</filename>
		<folder>vendor</folder>
	</files>
	<updateservers>
		<server type="extension" name="plg_system_markdownmirror">https://raw.githubusercontent.com/Buchs-Dev/markdownmirror/master/updates.xml</server>
	</updateservers>
</extension>